{
  "name": "playwright-mcp-no-llm-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Drive Playwright MCP from a deterministic Node.js client to validate a frontend app — no LLM involved.",
  "scripts": {
    "app": "vite app",
    "app:build": "vite build app",
    "app:preview": "vite preview app --port=5173",
    "validate": "node validator/run.mjs",
    "demo": "node validator/run.mjs --start-app",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "lint:md": "markdownlint-cli2",
    "lint:md:fix": "markdownlint-cli2 --fix",
    "format": "biome format --write .",
    "check": "biome check . && markdownlint-cli2",
    "spec:compile": "node tools/compile-scenarios/compile.mjs",
    "spec:compile:ollama": "node tools/compile-scenarios/compile.mjs --provider=ollama",
    "spec:compile:dry-run": "node tools/compile-scenarios/compile.mjs --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/mcp": "^0.0.75",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "packageManager": "pnpm@11.0.3",
  "engines": {
    "node": ">=24.0.0 <25"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "markdownlint-cli2": "^0.22.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.13"
  }
}
